<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Protek Enerji Home Page - Based on protekenerji.com -->
    <template id="protek_home_page" name="Protek Enerji Home">
        <t t-call="website.layout">
            <t t-set="additional_title">Anasayfa</t>

            <div id="wrap" class="protek-home">
                <!-- Hero Section - Matching protekenerji.com carousel style -->
                <section class="protek-hero position-relative overflow-hidden">
                    <div class="protek-hero-bg"></div>
                    <div class="container position-relative py-5">
                        <div class="row align-items-center min-vh-50">
                            <div class="col-lg-7 text-white py-5">
                                <h1 class="display-4 fw-bold mb-4 animate__animated animate__fadeInDown">
                                    Yerli Isı Sayacı Üreticisi
                                </h1>
                                <p class="lead mb-4 animate__animated animate__fadeInUp">
                                    ProHeat Kalorimetre hibrit sistem tabanlı ısıtma ve soğutma sistemlerinde
                                    kullanılabilir. Uzun pil ömrü ve 25l/h gibi yüksek ölçüm hassasiyetine sahiptir.
                                </p>
                                <div class="protek-hero-buttons animate__animated animate__fadeInUp">
                                    <a href="/shop" class="btn btn-danger btn-lg me-3 mb-2">
                                        <i class="fa fa-shopping-cart me-2"></i> Ürünleri İncele
                                    </a>
                                    <a href="/protek/about" class="btn btn-outline-light btn-lg mb-2">
                                        <i class="fa fa-info-circle me-2"></i> Hakkımızda
                                    </a>
                                </div>
                            </div>
                            <div class="col-lg-5 d-none d-lg-block">
                                <div class="protek-hero-image text-center">
                                    <i class="fa fa-tachometer fa-10x text-white opacity-25"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- Icon Boxes Section - Matching protekenerji.com exactly -->
                <section class="protek-icon-boxes py-5">
                    <div class="container">
                        <div class="row g-4">
                            <div class="col-md-6 col-lg-3">
                                <div class="protek-feature-card card border-0 shadow-sm h-100 text-center p-4">
                                    <div class="protek-feature-icon mb-3">
                                        <i class="fa fa-tachometer fa-3x"></i>
                                    </div>
                                    <h4 class="title">ProHeat Kalorimetre</h4>
                                    <p class="description">
                                        ProHeat Kalorimetre hibrit sistem tabanlı ısıtma ve soğutma sistemlerinde
                                        kullanılabilir. Uzun pil ömrü ve yüksek ölçüm hassasiyetine sahiptir.
                                    </p>
                                </div>
                            </div>
                            <div class="col-md-6 col-lg-3">
                                <div class="protek-feature-card card border-0 shadow-sm h-100 text-center p-4">
                                    <div class="protek-feature-icon mb-3">
                                        <i class="fa fa-microchip fa-3x"></i>
                                    </div>
                                    <h4 class="title">PMG Serisi Dönüştürücüler</h4>
                                    <p class="description">
                                        PMG Serisi Dönüştürücüler Ethernet, GSM, USB ve Bluetooth seçenekleri ile
                                        birlikte M-Bus protokol haberleşme ürünleridir.
                                    </p>
                                </div>
                            </div>
                            <div class="col-md-6 col-lg-3">
                                <div class="protek-feature-card card border-0 shadow-sm h-100 text-center p-4">
                                    <div class="protek-feature-icon mb-3">
                                        <i class="fa fa-file-text-o fa-3x"></i>
                                    </div>
                                    <h4 class="title">Online Gider Paylaşım</h4>
                                    <p class="description">
                                        Online olarak merkezi sistem ısıtma, soğutma, elektrik, sıcak ve soğuk su
                                        gider paylaşımları konusunda uzman yardımcınız.
                                    </p>
                                </div>
                            </div>
                            <div class="col-md-6 col-lg-3">
                                <div class="protek-feature-card card border-0 shadow-sm h-100 text-center p-4">
                                    <div class="protek-feature-icon mb-3">
                                        <i class="fa fa-certificate fa-3x"></i>
                                    </div>
                                    <h4 class="title">Isı Sayacı Muayene Servisi</h4>
                                    <p class="description">
                                        Bakanlık onaylı ısı sayacı muayene laboratuvarlarımızda, müşterilerimize
                                        servis ve ürünlerimizde en üst kalitede hizmet sunmaktayız.
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- About Section -->
                <section class="protek-about py-5 bg-light">
                    <div class="container">
                        <div class="row align-items-center">
                            <div class="col-lg-6 mb-4 mb-lg-0">
                                <div class="protek-about-image bg-white rounded p-5 text-center shadow-sm">
                                    <i class="fa fa-building fa-8x" style="color: #0A2251; opacity: 0.3;"></i>
                                </div>
                            </div>
                            <div class="col-lg-6">
                                <h2 class="fw-bold mb-4" style="color: #0A2251;">Protek Enerji Hizmetleri</h2>
                                <p class="text-muted mb-4">
                                    Protek Enerji Hizmetleri merkezi ısıtma, soğutma, elektrik, sıcak ve soğuk su
                                    sistemlerinde profesyonel çözümler üretir. Isı Sayacı (Kalorimetre) sistemlerinde
                                    Türkiye'nin öncü firmalarından biriyiz.
                                </p>
                                <ul class="list-unstyled">
                                    <li class="mb-2">
                                        <i class="fa fa-check-circle me-2" style="color: #E3000F;"></i>
                                        Yerli Üretim Kalite Garantisi
                                    </li>
                                    <li class="mb-2">
                                        <i class="fa fa-check-circle me-2" style="color: #E3000F;"></i>
                                        Bakanlık Onaylı Muayene Hizmeti
                                    </li>
                                    <li class="mb-2">
                                        <i class="fa fa-check-circle me-2" style="color: #E3000F;"></i>
                                        7/24 Teknik Destek
                                    </li>
                                    <li class="mb-2">
                                        <i class="fa fa-check-circle me-2" style="color: #E3000F;"></i>
                                        Online Gider Paylaşım Sistemleri
                                    </li>
                                </ul>
                                <a href="/shop" class="btn btn-danger mt-3">
                                    <i class="fa fa-arrow-right me-2"></i> Ürünleri Görüntüle
                                </a>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- CTA Section -->
                <section class="protek-cta py-5 text-white">
                    <div class="container text-center">
                        <h2 class="fw-bold mb-3">Hemen Alışverişe Başlayın</h2>
                        <p class="lead mb-4">
                            Hesap oluşturarak ürünlerimize erişebilir ve sipariş verebilirsiniz.
                        </p>
                        <t t-if="request.env.user._is_public()">
                            <a href="/web/signup" class="btn btn-light btn-lg me-3">
                                <i class="fa fa-user-plus me-2"></i> Kayıt Ol
                            </a>
                            <a href="/web/login" class="btn btn-outline-light btn-lg">
                                <i class="fa fa-sign-in me-2"></i> Giriş Yap
                            </a>
                        </t>
                        <t t-else="">
                            <a href="/shop" class="btn btn-light btn-lg">
                                <i class="fa fa-shopping-cart me-2"></i> Ürünleri İncele
                            </a>
                        </t>
                    </div>
                </section>
            </div>
        </t>
    </template>

    <!-- About Page -->
    <template id="protek_about_page" name="Protek Enerji About">
        <t t-call="website.layout">
            <t t-set="additional_title">About Us</t>

            <div id="wrap" class="protek-about">
                <!-- Page Header -->
                <section class="protek-page-header bg-dark text-white py-5">
                    <div class="container">
                        <div class="row">
                            <div class="col-12 text-center">
                                <h1 class="display-5 fw-bold">About Protek Enerji</h1>
                                <nav aria-label="breadcrumb">
                                    <ol class="breadcrumb justify-content-center mb-0">
                                        <li class="breadcrumb-item"><a href="/protek/home" class="text-white">Home</a></li>
                                        <li class="breadcrumb-item active text-danger" aria-current="page">About Us</li>
                                    </ol>
                                </nav>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- About Content -->
                <section class="py-5">
                    <div class="container">
                        <div class="row align-items-center">
                            <div class="col-lg-6 mb-4 mb-lg-0">
                                <div class="protek-about-image bg-light rounded p-5 text-center">
                                    <i class="fa fa-building fa-10x text-danger opacity-50"></i>
                                </div>
                            </div>
                            <div class="col-lg-6">
                                <h2 class="fw-bold mb-4">Our Story</h2>
                                <p class="lead text-muted mb-4">
                                    Protek Enerji has been a leading provider of energy solutions
                                    in Turkey for over a decade.
                                </p>
                                <p class="text-muted mb-4">
                                    Founded with a vision to provide high-quality energy products
                                    and exceptional customer service, we have grown to become a
                                    trusted partner for businesses and individuals alike.
                                </p>
                                <p class="text-muted mb-4">
                                    Our commitment to quality, innovation, and customer satisfaction
                                    drives everything we do. We carefully select each product in our
                                    catalog to ensure it meets our strict standards for performance
                                    and reliability.
                                </p>
                                <div class="row g-3 mt-4">
                                    <div class="col-6">
                                        <div class="d-flex align-items-center">
                                            <i class="fa fa-check-circle fa-2x text-danger me-3"></i>
                                            <span>Quality Assured</span>
                                        </div>
                                    </div>
                                    <div class="col-6">
                                        <div class="d-flex align-items-center">
                                            <i class="fa fa-check-circle fa-2x text-danger me-3"></i>
                                            <span>Expert Support</span>
                                        </div>
                                    </div>
                                    <div class="col-6">
                                        <div class="d-flex align-items-center">
                                            <i class="fa fa-check-circle fa-2x text-danger me-3"></i>
                                            <span>Fast Shipping</span>
                                        </div>
                                    </div>
                                    <div class="col-6">
                                        <div class="d-flex align-items-center">
                                            <i class="fa fa-check-circle fa-2x text-danger me-3"></i>
                                            <span>Best Prices</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- Mission & Vision -->
                <section class="py-5 bg-light">
                    <div class="container">
                        <div class="row g-4">
                            <div class="col-md-6">
                                <div class="card border-0 shadow-sm h-100">
                                    <div class="card-body p-4">
                                        <div class="protek-icon-box mb-3">
                                            <i class="fa fa-bullseye fa-2x text-danger"></i>
                                        </div>
                                        <h4 class="fw-bold">Our Mission</h4>
                                        <p class="text-muted mb-0">
                                            To provide our customers with the highest quality energy
                                            products and solutions, backed by exceptional service and
                                            technical expertise. We strive to make energy solutions
                                            accessible and affordable for everyone.
                                        </p>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="card border-0 shadow-sm h-100">
                                    <div class="card-body p-4">
                                        <div class="protek-icon-box mb-3">
                                            <i class="fa fa-eye fa-2x text-danger"></i>
                                        </div>
                                        <h4 class="fw-bold">Our Vision</h4>
                                        <p class="text-muted mb-0">
                                            To be the most trusted and innovative energy solutions
                                            provider in Turkey and beyond. We envision a future where
                                            clean, efficient energy is available to all, and we're
                                            committed to making that vision a reality.
                                        </p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>
            </div>
        </t>
    </template>

    <!-- Contact Page -->
    <template id="protek_contact_page" name="Protek Enerji Contact">
        <t t-call="website.layout">
            <t t-set="additional_title">Contact Us</t>

            <div id="wrap" class="protek-contact">
                <!-- Page Header -->
                <section class="protek-page-header bg-dark text-white py-5">
                    <div class="container">
                        <div class="row">
                            <div class="col-12 text-center">
                                <h1 class="display-5 fw-bold">Contact Us</h1>
                                <nav aria-label="breadcrumb">
                                    <ol class="breadcrumb justify-content-center mb-0">
                                        <li class="breadcrumb-item"><a href="/protek/home" class="text-white">Home</a></li>
                                        <li class="breadcrumb-item active text-danger" aria-current="page">Contact</li>
                                    </ol>
                                </nav>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- Contact Content -->
                <section class="py-5">
                    <div class="container">
                        <div class="row g-4">
                            <!-- Contact Info -->
                            <div class="col-lg-4">
                                <div class="protek-contact-info">
                                    <h3 class="fw-bold mb-4">Get In Touch</h3>
                                    <p class="text-muted mb-4">
                                        Have questions? We'd love to hear from you.
                                        Send us a message and we'll respond as soon as possible.
                                    </p>

                                    <div class="protek-contact-item d-flex mb-4">
                                        <div class="protek-contact-icon me-3">
                                            <i class="fa fa-map-marker fa-2x text-danger"></i>
                                        </div>
                                        <div>
                                            <h5 class="mb-1">Address</h5>
                                            <p class="text-muted mb-0">Yenişehir Mah. Kardeşler Cad. No:7/2 Cumhuriyet Teknokent Merkez/SİVAS</p>
                                        </div>
                                    </div>

                                    <div class="protek-contact-item d-flex mb-4">
                                        <div class="protek-contact-icon me-3">
                                            <i class="fa fa-phone fa-2x text-danger"></i>
                                        </div>
                                        <div>
                                            <h5 class="mb-1">Phone</h5>
                                            <p class="text-muted mb-0">0850 441 58 60</p>
                                        </div>
                                    </div>

                                    <div class="protek-contact-item d-flex mb-4">
                                        <div class="protek-contact-icon me-3">
                                            <i class="fa fa-envelope fa-2x text-danger"></i>
                                        </div>
                                        <div>
                                            <h5 class="mb-1">Email</h5>
                                            <p class="text-muted mb-0">info@protekenerji.com</p>
                                        </div>
                                    </div>

                                    <div class="protek-contact-item d-flex">
                                        <div class="protek-contact-icon me-3">
                                            <i class="fa fa-clock-o fa-2x text-danger"></i>
                                        </div>
                                        <div>
                                            <h5 class="mb-1">Working Hours</h5>
                                            <p class="text-muted mb-0">Mon - Fri: 09:00 - 18:00</p>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Contact Form -->
                            <div class="col-lg-8">
                                <div class="card border-0 shadow-sm">
                                    <div class="card-body p-4">
                                        <h3 class="fw-bold mb-4">Send Us a Message</h3>
                                        <form action="/website/form/" method="post" class="s_website_form">
                                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                            <div class="row g-3">
                                                <div class="col-md-6">
                                                    <label class="form-label">Full Name *</label>
                                                    <input type="text" name="name" class="form-control" required="required"/>
                                                </div>
                                                <div class="col-md-6">
                                                    <label class="form-label">Email Address *</label>
                                                    <input type="email" name="email" class="form-control" required="required"/>
                                                </div>
                                                <div class="col-md-6">
                                                    <label class="form-label">Phone Number</label>
                                                    <input type="tel" name="phone" class="form-control"/>
                                                </div>
                                                <div class="col-md-6">
                                                    <label class="form-label">Subject</label>
                                                    <input type="text" name="subject" class="form-control"/>
                                                </div>
                                                <div class="col-12">
                                                    <label class="form-label">Message *</label>
                                                    <textarea name="message" class="form-control" rows="5" required="required"></textarea>
                                                </div>
                                                <div class="col-12">
                                                    <button type="submit" class="btn btn-danger btn-lg">
                                                        <i class="fa fa-paper-plane me-2"></i> Send Message
                                                    </button>
                                                </div>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>
            </div>
        </t>
    </template>
</odoo>


