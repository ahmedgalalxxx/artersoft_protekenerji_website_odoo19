<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Checkout Steps Progress Template (standalone) -->
    <template id="protek_checkout_progress" name="Protek Checkout Progress">
        <div class="protek-checkout-progress mb-4">
            <div class="container">
                <div class="row">
                    <div class="col-12">
                        <div class="d-flex justify-content-between align-items-center">
                            <div class="protek-step text-center">
                                <div class="protek-step-icon rounded-circle bg-success text-white mx-auto mb-2" style="width:50px;height:50px;display:flex;align-items:center;justify-content:center;">
                                    <i class="fa fa-shopping-cart"></i>
                                </div>
                                <small>Cart</small>
                            </div>
                            <div class="flex-grow-1 mx-2" style="height:3px;background:#dee2e6;"></div>
                            <div class="protek-step text-center">
                                <div class="protek-step-icon rounded-circle bg-light mx-auto mb-2" style="width:50px;height:50px;display:flex;align-items:center;justify-content:center;">
                                    <i class="fa fa-map-marker"></i>
                                </div>
                                <small>Address</small>
                            </div>
                            <div class="flex-grow-1 mx-2" style="height:3px;background:#dee2e6;"></div>
                            <div class="protek-step text-center">
                                <div class="protek-step-icon rounded-circle bg-light mx-auto mb-2" style="width:50px;height:50px;display:flex;align-items:center;justify-content:center;">
                                    <i class="fa fa-credit-card"></i>
                                </div>
                                <small>Payment</small>
                            </div>
                            <div class="flex-grow-1 mx-2" style="height:3px;background:#dee2e6;"></div>
                            <div class="protek-step text-center">
                                <div class="protek-step-icon rounded-circle bg-light mx-auto mb-2" style="width:50px;height:50px;display:flex;align-items:center;justify-content:center;">
                                    <i class="fa fa-check"></i>
                                </div>
                                <small>Confirm</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </template>

    <!-- Checkout Breadcrumb Template (standalone) -->
    <template id="protek_checkout_breadcrumb" name="Protek Checkout Breadcrumb">
        <nav aria-label="breadcrumb" class="protek-breadcrumb mb-3">
            <ol class="breadcrumb bg-light py-2 px-3 rounded">
                <li class="breadcrumb-item">
                    <a href="/protek/home"><i class="fa fa-home"></i> Home</a>
                </li>
                <li class="breadcrumb-item">
                    <a href="/shop">Shop</a>
                </li>
                <li class="breadcrumb-item">
                    <a href="/shop/cart">Cart</a>
                </li>
                <li class="breadcrumb-item active" aria-current="page">Checkout</li>
            </ol>
        </nav>
    </template>
</odoo>

