<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Empty Cart Template (standalone) -->
    <template id="protek_empty_cart" name="Protek Empty Cart">
        <div class="protek-empty-cart text-center py-5">
            <div class="protek-empty-icon mb-4">
                <i class="fa fa-shopping-cart fa-5x text-muted"></i>
            </div>
            <h3 class="text-muted">Your Cart is Empty</h3>
            <p class="text-muted mb-4">
                Looks like you haven't added anything to your cart yet.
            </p>
            <a href="/shop" class="btn btn-danger btn-lg">
                <i class="fa fa-shopping-bag me-2"></i> Start Shopping
            </a>
        </div>
    </template>

    <!-- Cart Breadcrumb Template (standalone) -->
    <template id="protek_cart_breadcrumb" name="Protek Cart Breadcrumb">
        <nav aria-label="breadcrumb" class="protek-breadcrumb mb-3">
            <ol class="breadcrumb bg-light py-2 px-3 rounded">
                <li class="breadcrumb-item">
                    <a href="/protek/home"><i class="fa fa-home"></i> Home</a>
                </li>
                <li class="breadcrumb-item">
                    <a href="/shop">Shop</a>
                </li>
                <li class="breadcrumb-item active" aria-current="page">Cart</li>
            </ol>
        </nav>
    </template>
</odoo>

