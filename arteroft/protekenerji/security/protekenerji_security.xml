<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Protek Enerji Customer Group -->
    <record id="group_protek_customer" model="res.groups">
        <field name="name">Protek Customer</field>
        <field name="comment">Users in this group can only access the shop and make purchases. They cannot access backend functionality.</field>
        <field name="implied_ids" eval="[(4, ref('base.group_portal'))]"/>
    </record>

    <!-- Security rule: Customers can only see their own orders -->
    <record id="rule_protek_customer_own_orders" model="ir.rule">
        <field name="name">Protek Customer: Own Orders Only</field>
        <field name="model_id" ref="sale.model_sale_order"/>
        <field name="groups" eval="[(4, ref('group_protek_customer'))]"/>
        <field name="domain_force">[('partner_id', '=', user.partner_id.id)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- Security rule: Customers can see published products -->
    <record id="rule_protek_customer_products" model="ir.rule">
        <field name="name">Protek Customer: Published Products</field>
        <field name="model_id" ref="product.model_product_template"/>
        <field name="groups" eval="[(4, ref('group_protek_customer'))]"/>
        <field name="domain_force">[('website_published', '=', True)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>
</odoo>

